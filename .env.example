# Общие переменные окружения Lapushka 5

APP_ENV=development
LOG_LEVEL=INFO

# Общая БД реестра задач
TASK_REGISTRY_DB_URL=sqlite:///./task_registry.db

# Google Sheets dashboard
GOOGLE_SHEETS_DASHBOARD_ID=
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=

# Google Drive
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=

# Yandex Disk
YANDEX_DISK_TOKEN=

# Общие сетевые настройки
HOST=0.0.0.0

# Порты модулей
INGEST_REGISTRY_PORT=8101
DOC_CLASSIFIER_PORT=8102
PROJECT_BUILDER_PORT=8103
ORCHESTRATOR_PORT=8201
SHELL_PORT=8301
